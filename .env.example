# Hardened baseline. Copy to .env and fill in real values via your secret manager.
NODE_ENV=production
PORT=3000

# 32+ random bytes (e.g. `openssl rand -hex 32`). Never commit a real value.
JWT_SECRET=replace-with-random-hex-string-of-at-least-32-bytes

# Stripe keys belong in a secret manager, not in env files committed to git.
STRIPE_SECRET_KEY=replace-with-secret-manager-reference
STRIPE_PUBLISHABLE_KEY=replace-with-publishable-key

# Database credentials injected at runtime by the orchestrator.
DB_PASSWORD=replace-with-secret-manager-reference
